{% assign tags = include.tags | split:'|' | sort | uniq %}

{% if tags.size > 0 %}
  <div class="tag-list">
    <ul>
      {% if tags.size == 1 %}
        <li class="meta">{{ site.data.language.str_tag| default: "Tag" }}</li>
      {% else %}
        <li class="meta">{{ site.data.language.str_tags | default: "Tags" }}</li>
      {% endif %}

      {% for tag in tags %}
        <li><a class="button" href="#{{ tag | cgi_escape }}">
          <p><i class="fas fa-tag fa-fw fa-sm"></i> {{ tag }}</p>
        </a></li>
      {% endfor %}
    </ul>
  </div>
{% else %}
  <div class="tag-list"></div>
{% endif %}
